---
const features = [
  { icon: "💰", title: "Control de Gastos", desc: "Categoriza y visualiza tus gastos automáticamente con inteligencia artificial.", color: "linear-gradient(135deg, #667eea, #764ba2)" },
  { icon: "📊", title: "Presupuestos", desc: "Crea presupuestos mensuales personalizados y recibe alertas cuando te acerques al límite.", color: "linear-gradient(135deg, #f093fb, #f5576c)" },
  { icon: "🎯", title: "Metas de Ahorro", desc: "Define metas financieras y ahorra automáticamente con redondeo inteligente.", color: "linear-gradient(135deg, #4facfe, #00f2fe)" },
  { icon: "💳", title: "Todas tus Cuentas", desc: "Conecta BCP, BBVA, Interbank y más en un solo lugar. Una vista completa.", color: "linear-gradient(135deg, #43e97b, #38f9d7)" },
  { icon: "📈", title: "Inversiones", desc: "Invierte desde S/ 10 en fondos diversificados. Sin comisiones ocultas.", color: "linear-gradient(135deg, #fa709a, #fee140)" },
  { icon: "🔔", title: "Alertas Inteligentes", desc: "Notificaciones de gastos inusuales, vencimientos y oportunidades de ahorro.", color: "linear-gradient(135deg, #a18cd1, #fbc2eb)" },
];
---

<section class="section" id="caracteristicas">
  <div class="container">
    <div class="text-center" style="margin-bottom: 64px;">
      <span class="section-label">Características</span>
      <h2 class="section-title">Todo lo que necesitas para<br><span class="gradient-text">controlar tu dinero</span></h2>
      <p class="section-subtitle mx-auto">Herramientas poderosas y fáciles de usar para que tomes el control total de tus finanzas personales.</p>
    </div>

    <div class="features-grid">
      {features.map(f => (
        <div class="feature-card glass-card">
          <div class="feature-icon" style={`background: ${f.color}`}>
            <span>{f.icon}</span>
          </div>
          <h3 class="feature-title">{f.title}</h3>
          <p class="feature-desc">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .feature-card {
    padding: 32px;
    border-radius: var(--radius-lg);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .feature-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--gradient-1);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .feature-card:hover::before {
    opacity: 1;
  }

  .feature-icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    font-size: 1.5rem;
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
  }

  .feature-icon span {
    filter: grayscale(0);
  }

  .feature-title {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--primary);
  }

  .feature-desc {
    font-size: 0.9rem;
    color: var(--text-light);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
