---
const stats = [
  { value: "S/ 50M+", label: "ahorrados por usuarios" },
  { value: "100,000+", label: "descargas activas" },
  { value: "4.8★", label: "rating promedio" },
  { value: "95%", label: "satisfacción" },
];
---

<section class="section stats">
  <div class="container">
    <div class="text-center" style="margin-bottom: 64px;">
      <span class="section-label">Impacto</span>
      <h2 class="section-title">Números que <span class="gradient-text">hablan por sí solos</span></h2>
    </div>

    <div class="stats-grid">
      {stats.map(s => (
        <div class="stat-card">
          <div class="stat-value gradient-text">{s.value}</div>
          <div class="stat-label">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats {
    background: var(--bg-alt);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .stat-card {
    text-align: center;
    padding: 36px 24px;
    background: #fff;
    border-radius: var(--radius-lg);
    border: 1px solid #f1f5f9;
    transition: all 0.3s ease;
  }

  .stat-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .stat-value {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 900;
    margin-bottom: 8px;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.95rem;
    color: var(--text-light);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
