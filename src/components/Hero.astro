---
---

<section class="hero">
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>

  <div class="container hero-inner">
    <div class="hero-content">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        <span>Nuevo: Inversiones desde S/ 10</span>
      </div>

      <h1 class="hero-title">
        Tu dinero bajo control. <span class="gradient-text">Siempre.</span>
      </h1>

      <p class="hero-subtitle">
        La app de finanzas personales que te ayuda a ahorrar, invertir y alcanzar tus metas financieras. Disponible en todo el Perú.
      </p>

      <div class="hero-buttons">
        <a href="#descargar" class="btn btn-primary">
          Descargar Gratis
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="#demo" class="btn btn-secondary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
          Ver Demo
        </a>
      </div>

      <div class="hero-stats">
        <div class="hero-stat">
          <strong>100,000+</strong>
          <span>descargas</span>
        </div>
        <div class="stat-divider"></div>
        <div class="hero-stat">
          <strong>4.8 ★</strong>
          <span>rating</span>
        </div>
        <div class="stat-divider"></div>
        <div class="hero-stat">
          <strong>Gratis</strong>
          <span>para empezar</span>
        </div>
      </div>
    </div>

    <div class="hero-phone-wrapper">
      <!-- Floating notifications -->
      <div class="floating-bubble bubble-1 animate-float">
        <span class="bubble-icon">💰</span>
        <div>
          <div class="bubble-title">+S/ 500 ahorrado</div>
          <div class="bubble-sub">Este mes</div>
        </div>
      </div>

      <div class="floating-bubble bubble-2 animate-float-delayed">
        <span class="bubble-icon">🎉</span>
        <div>
          <div class="bubble-title">Meta cumplida</div>
          <div class="bubble-sub">Viaje a Cusco</div>
        </div>
      </div>

      <div class="phone-mockup">
        <div class="phone-screen">
          <!-- App UI simulation -->
          <div class="app-header-bar">
            <div class="app-greeting">Hola, María 👋</div>
            <div class="app-notification-dot"></div>
          </div>

          <div class="app-balance-card">
            <div class="app-balance-label">Balance total</div>
            <div class="app-balance-amount">S/ 12,450.00</div>
            <div class="app-balance-change">+12.5% este mes</div>
          </div>

          <div class="app-quick-actions">
            <div class="app-action"><span>📤</span><small>Enviar</small></div>
            <div class="app-action"><span>📥</span><small>Recibir</small></div>
            <div class="app-action"><span>📊</span><small>Invertir</small></div>
            <div class="app-action"><span>🎯</span><small>Metas</small></div>
          </div>

          <div class="app-savings-section">
            <div class="app-section-title">Meta de ahorro</div>
            <div class="app-goal-name">Viaje a Cusco - S/ 2,800 / S/ 3,500</div>
            <div class="app-progress-bar">
              <div class="app-progress-fill" style="width: 80%"></div>
            </div>
          </div>

          <div class="app-transactions">
            <div class="app-section-title">Últimos movimientos</div>
            <div class="app-tx">
              <span class="tx-icon">🛒</span>
              <div class="tx-info"><div class="tx-name">Plaza Vea</div><div class="tx-date">Hoy</div></div>
              <div class="tx-amount negative">-S/ 85.50</div>
            </div>
            <div class="app-tx">
              <span class="tx-icon">💼</span>
              <div class="tx-info"><div class="tx-name">Sueldo</div><div class="tx-date">Ayer</div></div>
              <div class="tx-amount positive">+S/ 4,200</div>
            </div>
            <div class="app-tx">
              <span class="tx-icon">☕</span>
              <div class="tx-info"><div class="tx-name">Starbucks</div><div class="tx-date">Ayer</div></div>
              <div class="tx-amount negative">-S/ 18.90</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 140px 0 100px;
    overflow: hidden;
    background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
  }

  .hero-inner {
    display: flex;
    align-items: center;
    gap: 60px;
    position: relative;
    z-index: 1;
  }

  .hero-content {
    flex: 1;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(129, 140, 248, 0.1);
    border: 1px solid rgba(129, 140, 248, 0.2);
    border-radius: 100px;
    padding: 6px 16px;
    font-size: 0.85rem;
    font-weight: 600;
    color: #667eea;
    margin-bottom: 24px;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    background: var(--accent-2);
    border-radius: 50%;
    animation: pulse-glow 2s ease-in-out infinite;
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 20px;
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: var(--text-light);
    line-height: 1.7;
    margin-bottom: 36px;
    max-width: 500px;
  }

  .hero-buttons {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 48px;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .hero-stat strong {
    display: block;
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--primary);
  }

  .hero-stat span {
    font-size: 0.8rem;
    color: var(--text-light);
  }

  .stat-divider {
    width: 1px;
    height: 36px;
    background: #e2e8f0;
  }

  /* Phone wrapper */
  .hero-phone-wrapper {
    position: relative;
    flex-shrink: 0;
  }

  /* Floating bubbles */
  .floating-bubble {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: 16px;
    padding: 12px 16px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    z-index: 10;
    white-space: nowrap;
  }

  .bubble-1 {
    top: 60px;
    left: -100px;
  }

  .bubble-2 {
    bottom: 100px;
    right: -80px;
  }

  .bubble-icon {
    font-size: 1.5rem;
  }

  .bubble-title {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--primary);
  }

  .bubble-sub {
    font-size: 0.75rem;
    color: var(--text-light);
  }

  /* App UI inside phone */
  .app-header-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 40px 16px 12px;
  }

  .app-greeting {
    color: #fff;
    font-weight: 600;
    font-size: 0.8rem;
  }

  .app-notification-dot {
    width: 8px;
    height: 8px;
    background: var(--accent-3);
    border-radius: 50%;
  }

  .app-balance-card {
    margin: 0 12px 12px;
    background: rgba(255, 255, 255, 0.12);
    border-radius: 16px;
    padding: 16px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .app-balance-label {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.65rem;
    margin-bottom: 4px;
  }

  .app-balance-amount {
    color: #fff;
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 4px;
  }

  .app-balance-change {
    color: var(--accent-2);
    font-size: 0.65rem;
    font-weight: 600;
  }

  .app-quick-actions {
    display: flex;
    justify-content: space-around;
    padding: 8px 12px 12px;
  }

  .app-action {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .app-action span {
    font-size: 1.2rem;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 12px;
  }

  .app-action small {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.55rem;
  }

  .app-savings-section {
    margin: 4px 12px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 12px;
  }

  .app-section-title {
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.7rem;
    font-weight: 700;
    margin-bottom: 6px;
  }

  .app-goal-name {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.6rem;
    margin-bottom: 6px;
  }

  .app-progress-bar {
    height: 6px;
    background: rgba(255, 255, 255, 0.15);
    border-radius: 3px;
    overflow: hidden;
  }

  .app-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent-2), #818cf8);
    border-radius: 3px;
  }

  .app-transactions {
    margin: 8px 12px;
  }

  .app-tx {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .tx-icon {
    font-size: 0.9rem;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 8px;
  }

  .tx-info {
    flex: 1;
  }

  .tx-name {
    color: #fff;
    font-size: 0.65rem;
    font-weight: 600;
  }

  .tx-date {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.55rem;
  }

  .tx-amount {
    font-size: 0.7rem;
    font-weight: 700;
  }

  .tx-amount.negative { color: #f87171; }
  .tx-amount.positive { color: var(--accent-2); }

  @media (max-width: 768px) {
    .hero-inner {
      flex-direction: column;
      text-align: center;
    }

    .hero-subtitle {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-buttons {
      justify-content: center;
    }

    .hero-stats {
      justify-content: center;
    }

    .floating-bubble {
      display: none;
    }

    .phone-mockup {
      width: 240px;
      height: 480px;
    }
  }
</style>
