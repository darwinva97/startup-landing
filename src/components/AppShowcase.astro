---
const highlights = [
  { label: "Dashboard intuitivo", pos: "top-left" },
  { label: "Gastos por categoría", pos: "top-right" },
  { label: "Ahorro automático", pos: "bottom-left" },
  { label: "Inversiones simples", pos: "bottom-right" },
];
---

<section class="section showcase">
  <div class="container">
    <div class="text-center" style="margin-bottom: 64px;">
      <span class="section-label">La App</span>
      <h2 class="section-title">Diseñada para ser <span class="gradient-text">simple y poderosa</span></h2>
      <p class="section-subtitle mx-auto">Una interfaz intuitiva que pone toda la información que necesitas al alcance de tu mano.</p>
    </div>

    <div class="showcase-wrapper">
      <div class="showcase-highlight hl-top-left glass-card">
        <div class="hl-dot"></div>
        <span>Dashboard intuitivo</span>
        <div class="hl-line hl-line-tr"></div>
      </div>

      <div class="showcase-highlight hl-top-right glass-card">
        <div class="hl-dot"></div>
        <span>Gastos por categoría</span>
        <div class="hl-line hl-line-tl"></div>
      </div>

      <div class="phone-mockup showcase-phone">
        <div class="phone-screen">
          <div class="sc-header">
            <div class="sc-avatar"></div>
            <div class="sc-greeting">
              <div class="sc-name">María García</div>
              <div class="sc-sub">Plan Premium</div>
            </div>
            <div class="sc-bell">🔔</div>
          </div>

          <div class="sc-balance">
            <small>Balance total</small>
            <div class="sc-amount">S/ 12,450</div>
          </div>

          <div class="sc-categories">
            <div class="sc-cat">
              <div class="sc-cat-bar" style="height: 60%; background: #818cf8;"></div>
              <small>Comida</small>
            </div>
            <div class="sc-cat">
              <div class="sc-cat-bar" style="height: 40%; background: #34d399;"></div>
              <small>Trans.</small>
            </div>
            <div class="sc-cat">
              <div class="sc-cat-bar" style="height: 80%; background: #f472b6;"></div>
              <small>Casa</small>
            </div>
            <div class="sc-cat">
              <div class="sc-cat-bar" style="height: 30%; background: #fbbf24;"></div>
              <small>Otros</small>
            </div>
          </div>

          <div class="sc-savings">
            <div class="sc-save-header">
              <span>Ahorro automático</span>
              <span class="sc-save-toggle">ON</span>
            </div>
            <div class="sc-save-amount">S/ 200/mes</div>
            <div class="sc-save-bar"><div class="sc-save-fill"></div></div>
          </div>

          <div class="sc-invest">
            <div class="sc-invest-title">Mi portafolio</div>
            <div class="sc-invest-value">S/ 3,200 <span>+12%</span></div>
          </div>
        </div>
      </div>

      <div class="showcase-highlight hl-bottom-left glass-card">
        <div class="hl-dot dot-green"></div>
        <span>Ahorro automático</span>
        <div class="hl-line hl-line-br"></div>
      </div>

      <div class="showcase-highlight hl-bottom-right glass-card">
        <div class="hl-dot dot-pink"></div>
        <span>Inversiones simples</span>
        <div class="hl-line hl-line-bl"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .showcase {
    background: var(--bg);
    overflow: hidden;
  }

  .showcase-wrapper {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 620px;
  }

  .showcase-phone {
    z-index: 2;
    box-shadow: var(--shadow-xl), 0 0 80px rgba(102, 126, 234, 0.2);
  }

  .showcase-highlight {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 20px;
    border-radius: 14px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--primary);
    z-index: 3;
    white-space: nowrap;
  }

  .hl-dot {
    width: 10px;
    height: 10px;
    background: var(--accent);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .dot-green { background: var(--accent-2); }
  .dot-pink { background: var(--accent-3); }

  .hl-top-left { top: 60px; left: 10%; }
  .hl-top-right { top: 60px; right: 10%; }
  .hl-bottom-left { bottom: 60px; left: 10%; }
  .hl-bottom-right { bottom: 60px; right: 10%; }

  /* Phone screen content */
  .sc-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 40px 14px 10px;
  }

  .sc-avatar {
    width: 28px;
    height: 28px;
    background: linear-gradient(135deg, #818cf8, #f472b6);
    border-radius: 50%;
  }

  .sc-greeting { flex: 1; }
  .sc-name { color: #fff; font-size: 0.7rem; font-weight: 700; }
  .sc-sub { color: rgba(255,255,255,0.5); font-size: 0.55rem; }
  .sc-bell { font-size: 0.9rem; }

  .sc-balance {
    padding: 12px 14px;
  }
  .sc-balance small { color: rgba(255,255,255,0.6); font-size: 0.6rem; }
  .sc-amount { color: #fff; font-size: 1.6rem; font-weight: 800; }

  .sc-categories {
    display: flex;
    gap: 8px;
    padding: 0 14px;
    height: 80px;
    align-items: flex-end;
  }

  .sc-cat {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .sc-cat-bar {
    width: 100%;
    border-radius: 4px 4px 0 0;
  }

  .sc-cat small { color: rgba(255,255,255,0.5); font-size: 0.5rem; }

  .sc-savings {
    margin: 12px 14px;
    background: rgba(255,255,255,0.1);
    border-radius: 10px;
    padding: 10px;
  }

  .sc-save-header {
    display: flex;
    justify-content: space-between;
    color: #fff;
    font-size: 0.65rem;
    font-weight: 600;
  }

  .sc-save-toggle {
    color: var(--accent-2);
    font-weight: 700;
  }

  .sc-save-amount {
    color: rgba(255,255,255,0.7);
    font-size: 0.6rem;
    margin: 4px 0;
  }

  .sc-save-bar {
    height: 4px;
    background: rgba(255,255,255,0.15);
    border-radius: 2px;
  }

  .sc-save-fill {
    width: 65%;
    height: 100%;
    background: var(--accent-2);
    border-radius: 2px;
  }

  .sc-invest {
    margin: 8px 14px;
    background: rgba(255,255,255,0.08);
    border-radius: 10px;
    padding: 10px;
  }

  .sc-invest-title { color: #fff; font-size: 0.65rem; font-weight: 600; }
  .sc-invest-value { color: #fff; font-size: 1rem; font-weight: 800; margin-top: 4px; }
  .sc-invest-value span { color: var(--accent-2); font-size: 0.7rem; }

  @media (max-width: 768px) {
    .showcase-highlight {
      position: static;
    }

    .showcase-wrapper {
      flex-direction: column;
      gap: 16px;
      min-height: auto;
    }
  }
</style>
